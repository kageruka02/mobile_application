<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A4A40">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="≡"
                android:textColor="#4ECFB0"
                android:textSize="24sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="VIPER4ARISE FX"
                android:textColor="#4ECFB0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center_vertical"/>

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="⋮"
                android:textColor="#4ECFB0"
                android:textSize="24sp"
                android:gravity="center"/>
        </LinearLayout>

        <RadioGroup
            android:id="@+id/tabGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="4dp">

            <RadioButton
                android:id="@+id/tabHeadset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HEAD-\nSET"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:gravity="center"
                android:button="@null"
                android:checked="true"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginStart="-12dp"/>

            <RadioButton
                android:id="@+id/tabPhone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PHONE\nSPEAKER"
                android:textColor="#6AAA95"
                android:textSize="9sp"
                android:gravity="center"
                android:button="@null"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                />

            <RadioButton
                android:id="@+id/tabBluetooth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BLUE-\nTOOTH"
                android:textColor="#6AAA95"
                android:textSize="9sp"
                android:gravity="center"
                android:button="@null"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"/>

            <RadioButton
                android:id="@+id/tabUsb"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="USB/\nDOCK"
                android:textColor="#6AAA95"
                android:textSize="9sp"
                android:gravity="center"
                android:button="@null"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"/>
        </RadioGroup>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. Master Power -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    android:tint="#4ECFB0"
                    android:contentDescription="Master Power"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Master Power"
                    android:textColor="#DDDDDD"
                    android:textSize="14sp"
                    android:paddingStart="14dp"/>
                <com.example.myapplication.CustomSwitch
                    android:id="@+id/switchMasterPower"
                    android:layout_width="80dp"
                    android:layout_height="36dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A2A"/>

            <!-- 2. Playback Gain Control -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_media_play"
                    android:tint="#777777"
                    android:contentDescription="Playback Gain"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Playback Gain Control"
                    android:textColor="#DDDDDD"
                    android:textSize="14sp"
                    android:paddingStart="14dp"/>
                <com.example.myapplication.CustomSwitch
                    android:id="@+id/switchPlaybackGain"
                    android:layout_width="80dp"
                    android:layout_height="36dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A2A"/>

            <!-- 3. FET Compressor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:tint="#777777"
                    android:contentDescription="FET Compressor"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FET Compressor"
                    android:textColor="#DDDDDD"
                    android:textSize="14sp"
                    android:paddingStart="14dp"/>
                <com.example.myapplication.CustomSwitch
                    android:id="@+id/switchFETCompressor"
                    android:layout_width="80dp"
                    android:layout_height="36dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A2A"/>

            <!-- 4. ViPER-DDC -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="#777777"
                    android:contentDescription="ViPER DDC"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ViPER-DDC"
                        android:textColor="#DDDDDD"
                        android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/tvViperTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="#4ECFB0"
                        android:textSize="11sp"
                        android:visibility="gone"/>
                </LinearLayout>
                <com.example.myapplication.CustomSwitch
                    android:id="@+id/switchViperDDC"
                    android:layout_width="80dp"
                    android:layout_height="36dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A2A"/>

            <!-- 5. Spectrum Extension -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:tint="#777777"
                    android:contentDescription="Spectrum Extension"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Spectrum Extension"
                    android:textColor="#DDDDDD"
                    android:textSize="14sp"
                    android:paddingStart="14dp"/>
                <com.example.myapplication.CustomSwitch
                    android:id="@+id/switchSpectrumExtension"
                    android:layout_width="80dp"
                    android:layout_height="36dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A2A"/>

            <!-- 6. FIR Equalizer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_slideshow"
                    android:tint="#777777"
                    android:contentDescription="FIR Equalizer"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FIREqualizer"
                    android:textColor="#DDDDDD"
                    android:textSize="14sp"
                    android:paddingStart="14dp"/>
                <com.example.myapplication.CustomSwitch
                    android:id="@+id/switchFIREqualizer"
                    android:layout_width="80dp"
                    android:layout_height="36dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A2A"/>

            <!-- 7. Convolver -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:tint="#777777"
                    android:contentDescription="Convolver"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Convolver"
                    android:textColor="#DDDDDD"
                    android:textSize="14sp"
                    android:paddingStart="14dp"/>
                <com.example.myapplication.CustomSwitch
                    android:id="@+id/switchConvolver"
                    android:layout_width="80dp"
                    android:layout_height="36dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2A2A2A"/>

            <!-- 8. Field Surround -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_mapmode"
                    android:tint="#777777"
                    android:contentDescription="Field Surround"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Field Surround"
                    android:textColor="#DDDDDD"
                    android:textSize="14sp"
                    android:paddingStart="14dp"/>
                <com.example.myapplication.CustomSwitch
                    android:id="@+id/switchFieldSurround"
                    android:layout_width="80dp"
                    android:layout_height="36dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>